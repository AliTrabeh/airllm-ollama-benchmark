# airllm-ollama-benchmark — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# Source: software_submission_guidelines-V3 §7.4

# =============================================================================
# HuggingFace Authentication
# Required for downloading models from HuggingFace Hub.
# Get your token at: huggingface.co/settings/tokens
# =============================================================================
HF_TOKEN=

# =============================================================================
# Model Configuration
# These can also be set in config/setup.json — env vars override config file.
# =============================================================================

# HuggingFace model ID for standard baseline (small model, pipeline verification)
# Example: "TinyLlama/TinyLlama-1.1B-Chat-v1.0"
MODEL_ID=

# HuggingFace model ID for AirLLM experiment (large model, should be too big for normal RAM)
# Must be in SafeTensors format for AirLLM compatibility.
# Example: "mistralai/Mistral-7B-v0.1"
AIRLLM_MODEL_ID=

# Ollama model name (must be installed via: ollama pull <name>)
# Example: "tinyllama" or "llama3"
OLLAMA_MODEL=

# =============================================================================
# Inference Settings
# Start small! Verify the pipeline works before increasing.
# =============================================================================

# Maximum new tokens to generate (keep small: 20-50 for testing)
MAX_NEW_TOKENS=20

# Device for HF baseline: "cuda" if GPU available, otherwise "cpu"
DEVICE=cpu

# =============================================================================
# Storage Paths
# =============================================================================

# Directory for cached model weights (can be several GB)
# Default: ./models/
MODELS_DIR=

# Directory for benchmark results (JSON files)
# Default: ./results/
RESULTS_DIR=
